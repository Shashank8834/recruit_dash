# Google Sheets spreadsheet ID
# Found in the sheet URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Option A: Paste the entire service account JSON as a string (recommended for Docker)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Option B: Provide a path to the JSON key file instead
# GOOGLE_SERVICE_ACCOUNT_KEY=/app/service-account.json
# SERVICE_ACCOUNT_KEY_FILE=/path/on/host/to/service-account.json
